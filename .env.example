NEXT_PUBLIC_SITE_URL=https://example.com

# --- Stripe webhook → Meta Conversions API (server-side Purchase tracking) ---
# Set these in Vercel → Project → Settings → Environment Variables (NOT in the repo).
META_CAPI_TOKEN=            # Meta Conversions API access token
STRIPE_WEBHOOK_SECRET=      # Signing secret from the Stripe webhook (whsec_...)
# Optional:
META_PIXEL_ID=3295834153930056          # course dataset/pixel id (default already set in code)
META_TEST_EVENT_CODE=                   # e.g. TEST66157 to route to Test Events while testing

# --- Stripe Checkout (/api/create-checkout-session) ---
# Use TEST values locally, LIVE values in Vercel — same code, no change.
STRIPE_SECRET_KEY=          # sk_test_… locally, sk_live_… in Vercel
STRIPE_PRICE_ID=            # course $650 price id — test price locally, live price in Vercel
# Course price/product ids for reference:
#   live  price: price_1TdpdYDP91d10costjHL2GW2   product: prod_Ud5pxc1t9tJ2c7
#   test  price: price_1TdpdWE5ZSbFHm6SeZbuRRr7   product: prod_Ud5pl1WD0MVkf8

# --- Email (Resend) — transactional welcome emails ---
RESEND_API_KEY=                                  # from resend.com
EMAIL_FROM=AI Product Academy <hello@mail.raheelab.com>   # must be a Resend-verified domain
EMAIL_REPLY_TO=raheel@raheelab.com               # optional
